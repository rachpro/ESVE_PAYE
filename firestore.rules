rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - role: string (required, 'admin' or 'user')
    //   - displayName: string
    //
    // Collection: employees
    // Fields:
    //   - id: string
    //   - firstName: string
    //   - lastName: string
    //   - position: string
    //   - baseSalary: number
    //   - socialSecurityNumber: string
    //
    // Collection: payrollSlips
    // Fields:
    //   - id: string
    //   - employeeId: string
    //   - period: string
    //   - netPay: number
    //   - data: map
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "konerachid12@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) && request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));
    }

    match /employees/{employeeId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /payrollSlips/{slipId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
